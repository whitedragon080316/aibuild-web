# ====== 只需改這 4 項 ======
SITE_NAME=你的課程名稱
BRAND_NAME=你的品牌名
LINE_CHANNEL_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# ====== 以下有預設值，需要時再改 ======
ADMIN_USER_ID=your_line_user_id
PUBLIC_BASE_URL=https://your-domain.zeabur.app

# TapPay 金流
TAPPAY_APP_ID=12348
