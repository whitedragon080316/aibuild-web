# 直播場次 (格式: MMDD_標籤_YouTube連結)
# SESSION_1=0415_4/15 下午2點_https://youtube.com/live/xxx

# 回放連結
# REPLAY_URL=https://youtube.com/watch?v=xxx

# ====== Lumi（AI 顧問 7 題 coaching） ======
# LINE Dev Console 建 LIFF app 後取得
LIFF_ID=
# Lumi LIFF 完整 URL（LP / 直播頁主 CTA 用，點了會 LINE Login → 加好友 → 進診斷）
# 格式：https://liff.line.me/<LIFF_ID>
LUMI_LIFF_URL=
# Gemini API Key（AI 顧問回覆用；有 GEMINI_API_KEY 就夠，不用再設 AI_API_KEY）
GEMINI_API_KEY=
# Bot internal endpoint base URL（用於 Q7 報告推播）
BOT_INTERNAL_URL=https://your-bot.zeabur.app
# 與 bot 共用的 secret（web → bot /internal/push-report 驗證用），隨便一串長字串
LUMI_SHARED_SECRET=
# 報告 CTA 用
LIVESTREAM_URL=
BETA_SIGNUP_URL=
